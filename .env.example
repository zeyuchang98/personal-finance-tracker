# Plaid  (sign up free at https://dashboard.plaid.com — keys are per-environment)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
# production = your REAL banks. New Plaid accounts get a free Trial plan (up to 10
# banks, auto-approved, no review) so you can use real data right away. Use
# 'sandbox' only to demo with fake test data (login user_good / pass_good).
# The secret above must match the environment you pick here.
PLAID_ENV=production         # production | sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# Anthropic
